# Copy to `.env` in this directory and adjust. Values are read via `shared/config.py`
# (and `infra/aws.py` / orchestrator for a few extras). Optional keys can stay empty.

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
ANTHROPIC_MODEL=us.anthropic.claude-opus-4-6-v1
# ORCHESTRATOR_MODEL=
# RESEARCH_MODEL=

# --- API server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8420
# Base URL agents use to reach this server (required when server is not localhost:8420)
SERVER_URL=http://localhost:8420

DATA_DIR=data

# --- Agent run limits (seconds) ---
ENGINEER_TIMEOUT=1200
SCIENTIST_TIMEOUT=1200
HEARTBEAT_INTERVAL=30

# --- EC2 agent workers (optional) ---
# AMI_ID=
# AGENT_CODE_S3=s3://bucket/agent-code.tar.gz
INSTANCE_TYPE=c5.2xlarge
IAM_INSTANCE_PROFILE=research-agent-role
